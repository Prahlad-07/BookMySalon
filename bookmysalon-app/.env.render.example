# Render backend environment variables for bookmysalon-app

# Required
SPRING_DATASOURCE_URL=jdbc:mysql://<mysql-host>:3306/bookmysalon?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=<db-user>
SPRING_DATASOURCE_PASSWORD=<db-password>
SECURITY_JWT_SECRET=<base64-jwt-secret>
STRIPE_API_KEY=<stripe-secret-key>

# Required after frontend deployment (replace with your Vercel domain)
APP_CORS_ALLOWED_ORIGINS=https://<your-frontend>.vercel.app,http://localhost:3000,http://localhost:5173

# Optional
APP_OTP_DEV_MODE=true
MSG91_ENABLED=false
MSG91_AUTHKEY=
OTP_SMS_ENABLED=false
OTP_SMS_DEFAULT_COUNTRY_CODE=+91
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_FLYWAY_ENABLED=false
