# Render backend environment variables for bookmysalon-app

# Required
SECURITY_JWT_SECRET=<base64-jwt-secret>
STRIPE_API_KEY=<stripe-secret-key>

# Required for persistent storage (users, salons, bookings, services).
# Do not use embedded/in-memory databases in production.
SPRING_DATASOURCE_URL=jdbc:mysql://<mysql-host>:3306/bookmysalon?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=<db-user>
SPRING_DATASOURCE_PASSWORD=<db-password>
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

# Required after frontend deployment (replace with your Vercel domain)
APP_CORS_ALLOWED_ORIGIN_PATTERNS=https://<your-frontend>.vercel.app,http://localhost:3000,http://localhost:5173,https://*.vercel.app

# Optional
APP_OTP_DEV_MODE=false
OTP_EMAIL_ENABLED=true
OTP_EMAIL_FROM=<your-sender-email>
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=<your-smtp-username>
SPRING_MAIL_PASSWORD=<your-smtp-password-or-app-password>
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
APP_OAUTH2_ENABLED=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APP_OAUTH2_REDIRECT_URI=https://<your-frontend>.vercel.app/oauth/callback
APP_OAUTH2_FAILURE_URI=https://<your-frontend>.vercel.app/login
MSG91_ENABLED=false
MSG91_AUTHKEY=
OTP_SMS_ENABLED=false
OTP_SMS_DEFAULT_COUNTRY_CODE=+91
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_FLYWAY_ENABLED=false
